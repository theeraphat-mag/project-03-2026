pipeline {
    agent any
    stages {
        stage('Checkout') {
           steps {
                    // ไม่ต้องใส่ cleanWs() และไม่ต้องใส่ checkout scm ซ้ำ 
                    // เพราะ Jenkins ทำ Checkout ให้เสร็จแล้วตั้งแต่ต้น Stage
                    echo "Source code is already checked out by Jenkins."
                    sh "ls -la" // ลองใส่เพื่อเช็คดูว่าไฟล์ backend ยังอยู่ไหม
                }
            }

        stage('Build Docker Images') {
            steps {
                script {
                    // Build backend
                    echo "Building backend Image..."
                    sh "cd backend && docker build . -t tapootum/test-backend:${version}"
                }
            }
        }
        stage('Test Docker Images') {
            steps {
                script {
                    // ทดสอบรัน Container จาก Image ที่สร้างขึ้น
                    echo "Testing backend Image..."
                    sh "docker run --rm tapootum/test-backend:${version} echo 'backend Test Passed!'"
                }
            }
        }

        stage('Push to Docker Hub') {
            steps {
                script {
                    // Login to Docker Hub
                    withCredentials([usernamePassword(credentialsId: 'dockerhub', 
                                 usernameVariable: 'DUSER', 
                                 passwordVariable: 'DPASS')]) {
                    echo "Logging in to Docker Hub..."
                    sh "echo $DPASS | docker login -u $DUSER --password-stdin"

                    // Push backend Image
                    echo "Pushing backend Image to Docker Hub..."
                    sh "docker push tapootum/test-backend:${version}"
                    
                }
                }
            }
        }

        stage('Cleanup') {
            steps {
                sh "echo 'Cleaning up local Docker images...'"
                sh "docker rmi tapootum/test-backend:${version}"
                sh "docker logout"
                // ลบ Image ในเครื่อง Jenkins เพื่อประหยัดพื้นที่
            }
        }
    }
}
